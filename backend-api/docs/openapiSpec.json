  "components": {
    "schemas": {
      "Customer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "description": "customer name"
          },
          "password": {
            "type": "string",
            "description": "customer password"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "customer email"
          },
          "address": {
            "type": "string",
            "description": "customer address"
          },
          "phone": {
            "type": "string",
            "description": "customer phone number"
          },
          "avatar": {
            "type": "string",
            "readOnly": true,
            "description": "customer avatar file path"
          },
          "avatarFile": {
            "type": "string",
            "format": "binary",
            "writeOnly": true,
            "description": "customer avatar file"
          }
        }
      },
      "Cart":{
        "type":"object",
        "properties": {
          "id":{
            "type": "integer",
            "readOnly": true
          },
          "CustomerId":{
            "type": "integer",
            "description": "Id of the customer"
          }
        }
      },
      "OrderItem":{
        "type": "object",
        "properties": {
          "id":{
            "type": "integer",
            "readOnly": true
          },
          "ProductId":{
            "type": "integer",
            "readOnly": true
          },
          "OrderId":{
            "type": "integer"
          },
          "Quantity":{
            "type":"integer",
            "description": "Number of current item"
          },
          "Price":{
            "type":"string",
            "description": "Price of a single item of the product"
          }
        }
      },
      "Orders":{
        "type":"object",
        "properties": {
          "id":{
            "type":"integer",
            "readOnly": true
          },
          "CustomerId":{
            "type":"integer"
          },
          "date":{
            "type": "string",
            "format": "date",
            "description": "date create order"
          },
          "totalAmount":{
            "type":"string",
            "description": "the total amount of the order"
          }
        }
      },
      "Products":{
        "type":"object",
        "properties": {
          "id":{
            "type":"integer",
            "readOnly": true
          },
          "Name":{
            "type":"string",
            "description": "Name of the product"
          },
          "Category":{
            "type": "string",
            "description": "category of the product"
          },
          "Description":{
            "type": "string",
            "description": "Short summary of the product"
          },
          "Price":{
            "type":  "string",
            "description": "product price"
          },
          "QuantityAvailable":{
            "type": "integer",
            "description": "Number of stock available"
          },
          "image": {
            "type": "string",
            "readOnly": true,
            "description": "product image file path"
          },
          "imageFile": {
            "type": "string",
            "format": "binary",
            "writeOnly": true,
            "description": "product image file"
          }
        }
      }
    },
    "responses": {
      "200NoData": {
        "description": "No content",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "description": "The response status",
                  "enum": [
                    "success"
                  ]
                },
                "data": {
                  "type": ["object", "null"],
                  "default": null,
                  "description": "The response data"
                }
              }
            }
          }
        }
      },
      "400BadRequest": {
        "description": "Bad Request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "error"
                },
                "message": {
                  "type": "string",
