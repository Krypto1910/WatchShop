{
  "openapi": "3.1.1",
  "info": {
    "title": "Watchshop API",
    "version": "1.0.0",
    "description": "Watchshop API",
    "contact": {
      "name": "Thu Quang"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development server"
    }
  ],
  "paths": {
    "/api/v1/customers/register": {
      "post": {
        "summary": "Create a new customer",
        "description": "Create a new customer",
        "operationId": "createCustomer",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Customer"
              }
            }
          }
        },
        "tags": [
          "customers"
        ],
        "responses": {
          "201": {
            "description": "A new customer",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "The response status",
                      "enum": [
                        "success"
                      ]
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "customer": {
                          "$ref": "#/components/schemas/Customer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "$ref": "#/components/responses/400BadRequest"
          }
        }
      }
    },
    "/api/v1/customers/login": {
      "post": {
        "summary": "Check for customer",
        "description": "Check for customer",
        "operationId": "CheckCustomer",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/CustomerLogin"
              }
            }
          }
        },
        "tags": [
          "customers"
        ],
        "responses": {
          "201": {
            "description": "A new customer",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "The response status",
                      "enum": [
                        "success"
                      ]
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "customer": {
                          "$ref": "#/components/schemas/Customer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "$ref": "#/components/responses/400BadRequest"
          }
        }
      }
    },
    "/api/v1/customers/{id}": {
      "get": {
        "summary": "Get customer by ID",
        "description": "Get customer by ID",
        "operationId": "getCustomerById",
        "parameters": [
          {
            "$ref": "#/components/parameters/customerIdParam"
          }
        ],
        "tags": [
          "customers"
        ],
        "responses": {
          "200": {
            "description": "A customer",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "The response status",
                      "enum": [
                        "success"
                      ]
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "customer": {
                          "$ref": "#/components/schemas/Customer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "$ref": "#/components/responses/400BadRequest"
          }
        }
      },
      "put": {
        "summary": "Update customer by ID",
        "description": "Update customer by ID",
        "operationId": "updateCustomer",
        "parameters": [
          {
            "$ref": "#/components/parameters/customerIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Customer"
              }
            }
          }
        },
        "tags": [
          "customers"
        ],
        "responses": {
          "200": {
            "description": "An updated customer",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "The response status",
                      "enum": [
                        "success"
                      ]
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "customer": {
                          "$ref": "#/components/schemas/Customer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "$ref": "#/components/responses/400BadRequest"
          }
        }
      }
    },
    "/api/v1/orders": {
      "post": {
        "summary": "Create a new order",
        "operationId": "createOrder",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Orders"
              }
            }
          }
        },
        "tags": [
          "orders"
        ],
        "responses": {
          "201": {
            "description": "Order created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Orders"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400BadRequest"
          }
        }
      }
    },
    "/api/v1/orders/customer/{id}": {
      "get": {
        "summary": "Get Order by ID customer",
        "description": "Get Order by ID customer",
        "operationId": "getOrdersById",
        "parameters": [
          {
            "$ref": "#/components/parameters/orderIdParam"
          }
        ],
        "tags": [
          "orders"
        ],
        "responses": {
          "200": {
            "description": "An order",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "success"
                      ]
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "orders": {
                          "$ref": "#/components/schemas/Orders"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400BadRequest"
          }
        }
      }
    },
    "/api/v1/products": {
      "get": {
        "summary": "Get list of products",
        "description": "Returns a list of all products. You can optionally filter by category.",
        "tags": [
          "products"
        ],
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter products by category (case-insensitive match)"
          }
        ],
        "responses": {
          "200": {
            "description": "A list of product",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "success"
                      ]
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "products": {
                          "$ref": "#/components/schemas/Product"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400BadRequest"
          }
        }
      }
    },
    "/api/v1/products/{id}": {
      "get": {
        "summary": "Get Product by ID",
        "description": "Get Product by ID",
        "operationId": "getProductsById",
        "parameters": [
          {
            "$ref": "#/components/parameters/productIdParam"
          }
        ],
        "tags": [
          "products"
        ],
        "responses": {
          "200": {
            "description": "A product",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "success"
                      ]
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "products": {
                          "$ref": "#/components/schemas/Product"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400BadRequest"
          }
        }
      }
    },
    "/api/v1/products/search": {
      "get": {
        "summary": "Search products by name",
        "description": "Returns products that match the search query",
        "tags": [
          "products"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search term for product name"
          }
        ],
        "responses": {
          "200": {
            "description": "Matching products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "success"
                      ]
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "products": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Product"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400BadRequest"
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "message": {
                      "type": "string",
                      "example": "Internal server error"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/shipinfo": {
      "post": {
        "summary": "Create new shipping info",
        "operationId": "addShippingAddress",
        "tags": [
          "shipinfo"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ShipInfoRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Shipping info created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Ship info added successfully"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400BadRequest"
          },
          "405": {
            "$ref": "#/components/responses/405"
          }
        }
      }
    },
    "/api/v1/shipinfo/{customerId}": {
      "get": {
        "summary": "Get shipping info for customer",
        "operationId": "getShippingByCustomer",
        "tags": [
          "shipinfo"
        ],
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of shipping addresses found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "shipInfo": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ShipInfo"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/200NoData"
          },
          "400": {
            "$ref": "#/components/responses/400BadRequest"
          },
          "405": {
            "$ref": "#/components/responses/405"
          }
        }
      }
    },
    "/api/v1/shipinfo/{customerId}/{shipInfoId}": {
      "delete": {
        "summary": "Delete shipping info for customer",
        "operationId": "deleteShippingByCustomer",
        "tags": [
          "shipinfo"
        ],
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID of the customer"
          },
          {
            "name": "shipInfoId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID of the shipping info to delete"
          }
        ],
        "responses": {
          "200": {
            "description": "Shipping info deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Ship info deleted successfully"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Shipping info not found or does not belong to this customer",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "message": {
                      "type": "string",
                      "example": "Ship info not found or does not belong to this customer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400BadRequest"
          },
          "405": {
            "$ref": "#/components/responses/405"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Customer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "description": "customer name"
          },
          "password": {
            "type": "string",
            "description": "customer password"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "customer email"
          },
          "address": {
            "type": "string",
            "description": "customer address"
          },
          "phone": {
            "type": "string",
            "description": "customer phone number"
          }
        }
      },
      "CustomerLogin": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Customer's email"
          },
          "password": {
            "type": "string",
            "description": "Customer's password"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "Orders": {
        "type": "object",
        "properties": {
          "CustomerID": {
            "type": "integer",
            "description": "ID of the customer placing the order"
          },
          "Date": {
            "type": "string",
            "format": "date",
            "description": "Order date in YYYY-MM-DD format"
          },
          "TotalAmount": {
            "type": "number",
            "format": "float",
            "description": "Total amount for the order"
          },
          "Status": {
            "type": "string",
            "description": "Status of the order (e.g., Pending, Shipped)"
          },
          "Address": {
            "type": "string",
            "description": "Shipping address for the order"
          },
          "PaymentMethod": {
            "type": "string",
            "description": "Payment method (e.g., COD, Online Banking)"
          },
          "OrderItems": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ProductID": {
                  "type": "integer"
                },
                "Quantity": {
                  "type": "integer"
                },
                "UnitPrice": {
                  "type": "number"
                }
              },
              "required": [
                "ProductID",
                "Quantity",
                "UnitPrice"
              ]
            }
          }
        },
        "required": [
          "CustomerID",
          "Date",
          "TotalAmount",
          "Status",
          "Address",
          "PaymentMethod",
          "OrderItems"
        ]
      },
      "Product": {
        "type": "object",
        "properties": {
          "ProductID": {
            "type": "integer"
          },
          "Name": {
            "type": "string"
          },
          "Price": {
            "type": "number",
            "format": "float"
          },
          "Category": {
            "type": "string"
          },
          "QuantityAvailable": {
            "type": "integer"
          },
          "Image": {
            "type": "string"
          },
          "Description": {
            "type": "string"
          }
        }
      },
      "ShipInfo": {
        "type": "object",
        "properties": {
          "ShipInfoID": {
            "type": "integer"
          },
          "ContactName": {
            "type": "string"
          },
          "ContactNumber": {
            "type": "string"
          },
          "ShippingAddress": {
            "type": "string"
          }
        }
      },
      "ShipInfoRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Contact person's full name"
          },
          "phone": {
            "type": "string",
            "description": "Phone number"
          },
          "address": {
            "type": "string",
            "description": "Shipping address"
          },
          "customerID": {
            "type": "integer",
            "description": "Associated customer ID"
          }
        },
        "required": [
          "name",
          "phone",
          "address",
          "customerID"
        ]
      }
    },
    "responses": {
      "200NoData": {
        "description": "No content",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "description": "The response status",
                  "enum": [
                    "success"
                  ]
                },
                "data": {
                  "type": [
                    "object",
                    "null"
                  ],
                  "default": null,
                  "description": "The response data"
                }
              }
            }
          }
        }
      },
      "400BadRequest": {
        "description": "Bad Request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "error"
                },
                "message": {
                  "type": "string",
                  "example": "Invalid request parameters"
                }
              }
            }
          }
        }
      },
      "405": {
        "description": "Method Not Allowed",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "error"
                },
                "message": {
                  "type": "string",
                  "example": "Method Not Allowed"
                }
              }
            }
          }
        }
      }
    },
    "parameters": {
      "customerIdParam": {
        "name": "id",
        "description": "Customer ID",
        "required": true,
        "in": "path",
        "schema": {
          "type": "integer"
        }
      },
      "orderIdParam": {
        "name": "id",
        "description": "Order ID",
        "required": true,
        "in": "path",
        "schema": {
          "type": "integer"
        }
      },
      "productIdParam": {
        "name": "id",
        "description": "Product ID",
        "required": true,
        "in": "path",
        "schema": {
          "type": "integer"
        }
      }
    }
  },
  "tags": [
    {
      "name": "customers",
      "description": "Customer operations"
    },
    {
      "name": "orders",
      "description": "Order operations"
    },
    {
      "name": "products",
      "description": "Product operations"
    },
    {
      "name": "shipinfo",
      "description": "Shipping info operations"
    }
  ]
}